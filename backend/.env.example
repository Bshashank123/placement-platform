# ── Copy this to .env and fill in your values ──────────────────────────────

# PostgreSQL — create this DB manually before running:
#   psql -U postgres -c "CREATE DATABASE placement_platform;"
DATABASE_URL=postgresql://postgres:1234@localhost:5432/placement_platform

# JWT — change this to a long random string in production
JWT_SECRET_KEY=change-me-to-something-long-and-random
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_ENV=development
APP_NAME=Placement Readiness Platform
APP_VERSION=1.0.0
FRONTEND_URL=http://localhost:3000

# File Storage (Module 3+)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
